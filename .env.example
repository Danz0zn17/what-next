# ── Cloud server (Railway) ─────────────────────────────────────────────────────
# Set these on Railway via the dashboard or `railway variables set`
DATABASE_URL=postgresql://user:pass@host:5432/dbname
ENCRYPTION_SECRET=change-me-to-a-random-32-plus-char-string
PORT=3747

# ── API key auth ──────────────────────────────────────────────────────────────
# Shared secret for the /admin/users endpoint - generate a long random string
ADMIN_KEY=change-me-to-a-random-string

# ── Beta signup webhook ───────────────────────────────────────────────────────
# Must match WEBHOOK_SECRET in your Netlify environment variables
# Used by the Netlify function (netlify/functions/submission-created.js) to call
# POST /webhooks/beta-signup on the Railway server
WEBHOOK_SECRET=change-me-to-a-random-string

# ── Welcome email (Resend) ────────────────────────────────────────────────────
# Resend API key from resend.com
RESEND_API_KEY=re_your_resend_key_here
# Sender address - must be a verified domain in Resend
RESEND_FROM=What Next <noreply@whatnextai.co.za>

# ── Self-healing: Telegram alert on repeated errors (optional) ────────────────
# Format: https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>&text=
TELEGRAM_ALERT_URL=

# ── Local bridge (MCP server + local REST API) ────────────────────────────────
# Set these in ~/.claude/claude.json MCP env block and in your shell profile
WHATNEXT_CLOUD_URL=https://what-next-production.up.railway.app
WHATNEXT_API_KEY=bak_your_key_here

# ── GitHub Gist fallback (optional) ──────────────────────────────────────────
# Fine-grained PAT with Gist: read+write permission
GITHUB_TOKEN=ghp_your_token_here

# ── Local API server port (default 3747) ─────────────────────────────────────
WHATNEXT_PORT=3747

# ── Netlify function (set in Netlify dashboard, not here) ─────────────────────
# WEBHOOK_SECRET must also be set as an environment variable in Netlify
# (Site settings > Environment variables) so the function can call Railway
