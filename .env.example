# ── Cloud server (Railway) ─────────────────────────────────────────────────────
# Set these on Railway via the dashboard or `railway variables set`
DATABASE_URL=postgresql://user:pass@host:5432/dbname
ENCRYPTION_SECRET=change-me-to-a-random-32-plus-char-string
ADMIN_SECRET=change-me-to-another-secret
PORT=3747

# ── Local bridge (MCP server + local REST API) ────────────────────────────────
# Set these in ~/.claude/claude.json MCP env block and in your shell profile
WHATNEXT_CLOUD_URL=https://your-app.up.railway.app
WHATNEXT_API_KEY=bak_your_key_here

# ── GitHub Gist fallback (optional) ──────────────────────────────────────────
# Fine-grained PAT with Gist: read+write permission
GITHUB_TOKEN=ghp_your_token_here

# ── Local API server port (default 3747) ─────────────────────────────────────
WHATNEXT_PORT=3747
